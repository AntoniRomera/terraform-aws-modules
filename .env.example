# ---------------------------------------------------------------------------
# Example environment for running the Terraform configurations locally.
#
# Copy to .env and fill in real values (the .env file is git-ignored).
# Load it into your shell before running terraform, e.g.:
#
#   set -a && source .env && set +a
#   make validate
#
# NOTE: none of these are required to run `make fmt-check`, `make validate`,
# or `make lint` (those use -backend=false and need no AWS access). They are
# only needed for a real `terraform plan`/`apply` against AWS.
# ---------------------------------------------------------------------------

# --- AWS authentication ----------------------------------------------------
# Prefer a named profile or OIDC over static keys. If you use a profile,
# leave the access-key vars empty and set AWS_PROFILE instead.
AWS_PROFILE=my-aws-profile
AWS_REGION=eu-west-1

# Static keys are supported but discouraged. Leave blank when using a profile.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- Terraform input variables (TF_VAR_*) ----------------------------------
# Any module/example variable can be supplied via a TF_VAR_<name> env var
# instead of a *.tfvars file. The RDS master password is the most common one
# to keep out of version control. Leave unset to let the module auto-generate
# a random password (exposed as the sensitive `rds_password` output).
TF_VAR_db_password=change-me-use-a-strong-password
